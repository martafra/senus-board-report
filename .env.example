# Copy this file to .env and fill in real values. Never commit .env.

# Postgres (used by docker-compose db service; api reads DATABASE_URL directly)
DATABASE_URL=postgresql+asyncpg://senus:senus@localhost:5432/senus_board_report

# Google Gemini API key (free tier, aistudio.google.com) - required for AI extraction (Phase 3)
# and, locally, AI insights (Phase 6). Not used for insights when INSIGHT_PROXY_URL is set (see
# below): Google blocks direct Gemini calls from most cloud hosts, so the deployed API instead
# routes that one call through a small serverless function on Vercel that holds its own copy of
# this key. Leave INSIGHT_PROXY_URL empty locally, direct calls work fine from a residential IP.
GEMINI_API_KEY=

# Only needed when running on a cloud host (e.g. Render) where direct Gemini calls are blocked.
# INSIGHT_PROXY_URL: the deployed Vercel proxy, e.g. https://your-app.vercel.app/api/generate-insight
# INSIGHT_PROXY_SECRET: a random string, must match the same value set on the Vercel project
INSIGHT_PROXY_URL=
INSIGHT_PROXY_SECRET=

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=480

# Seeded demo login (created by scripts/seed_user.py)
DEMO_USER_EMAIL=ceo@senus.com
DEMO_USER_PASSWORD=change-me

# CORS - frontend origin allowed to call the API
WEB_ORIGIN=http://localhost:5173
